{
  "datasets": [
    {
      "name": "ds_total_users",
      "displayName": "Total Users",
      "query": "SELECT COUNT(DISTINCT attributes['user.id']) AS total_users FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code'"
    },
    {
      "name": "ds_total_cost",
      "displayName": "Total Cost",
      "query": "SELECT ROUND(SUM(CAST(attributes['cost_usd'] AS DOUBLE)), 2) AS total_cost_usd FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'api_request'"
    },
    {
      "name": "ds_total_tokens",
      "displayName": "Total Tokens",
      "query": "SELECT SUM(CAST(attributes['input_tokens'] AS BIGINT) + CAST(attributes['output_tokens'] AS BIGINT) + CAST(attributes['cache_read_tokens'] AS BIGINT) + CAST(attributes['cache_creation_tokens'] AS BIGINT)) AS total_tokens FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'api_request'"
    },
    {
      "name": "ds_total_sessions",
      "displayName": "Total Sessions",
      "query": "SELECT COUNT(DISTINCT attributes['session.id']) AS total_sessions FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code'"
    },
    {
      "name": "ds_active_time",
      "displayName": "Active Time",
      "query": "SELECT ROUND(SUM(CAST(attributes['duration_ms'] AS DOUBLE)) / 1000, 0) AS active_time_seconds FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'api_request'"
    },
    {
      "name": "ds_cost_over_time",
      "displayName": "Cost Over Time",
      "query": "SELECT DATE_TRUNC('HOUR', CAST(attributes['event.timestamp'] AS TIMESTAMP)) AS time_bucket, ROUND(SUM(CAST(attributes['cost_usd'] AS DOUBLE)), 4) AS cost_usd FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'api_request' GROUP BY 1 ORDER BY 1"
    },
    {
      "name": "ds_token_usage",
      "displayName": "Token Usage Over Time",
      "query": "SELECT DATE_TRUNC('HOUR', CAST(attributes['event.timestamp'] AS TIMESTAMP)) AS time_bucket, SUM(CAST(attributes['input_tokens'] AS BIGINT)) AS input_tokens, SUM(CAST(attributes['output_tokens'] AS BIGINT)) AS output_tokens, SUM(CAST(attributes['cache_read_tokens'] AS BIGINT)) AS cache_read_tokens, SUM(CAST(attributes['cache_creation_tokens'] AS BIGINT)) AS cache_creation_tokens FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'api_request' GROUP BY 1 ORDER BY 1"
    },
    {
      "name": "ds_event_volume",
      "displayName": "Event Volume by Type",
      "query": "SELECT DATE_TRUNC('HOUR', CAST(attributes['event.timestamp'] AS TIMESTAMP)) AS time_bucket, attributes['event.name'] AS event_type, COUNT(*) AS event_count FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] IN ('api_error', 'api_request', 'tool_decision', 'tool_result', 'user_prompt') GROUP BY 1, 2 ORDER BY 1"
    },
    {
      "name": "ds_lines_added",
      "displayName": "Lines of Code Added",
      "query": "/* lines_added attribute may not exist yet - placeholder */ SELECT COALESCE(SUM(CAST(attributes['lines_added'] AS BIGINT)), 0) AS lines_added FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'tool_result'"
    },
    {
      "name": "ds_lines_removed",
      "displayName": "Lines of Code Removed",
      "query": "/* lines_removed attribute may not exist yet - placeholder */ SELECT COALESCE(SUM(CAST(attributes['lines_removed'] AS BIGINT)), 0) AS lines_removed FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'tool_result'"
    },
    {
      "name": "ds_lines_over_time",
      "displayName": "Lines of Code Over Time",
      "query": "/* lines_added/lines_removed attributes may not exist yet - placeholder */ SELECT DATE_TRUNC('HOUR', CAST(attributes['event.timestamp'] AS TIMESTAMP)) AS time_bucket, COALESCE(SUM(CAST(attributes['lines_added'] AS BIGINT)), 0) AS lines_added, COALESCE(SUM(CAST(attributes['lines_removed'] AS BIGINT)), 0) AS lines_removed FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'tool_result' GROUP BY 1 ORDER BY 1"
    },
    {
      "name": "ds_git_commits",
      "displayName": "Git Commits",
      "query": "SELECT COUNT(*) AS git_commits FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'tool_result' AND attributes['tool_name'] LIKE '%Bash%' AND body LIKE '%git commit%'"
    },
    {
      "name": "ds_pull_requests",
      "displayName": "Pull Requests",
      "query": "SELECT COUNT(*) AS pull_requests FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'tool_result' AND attributes['tool_name'] LIKE '%Bash%' AND body LIKE '%gh pr create%'"
    },
    {
      "name": "ds_prs_over_time",
      "displayName": "PRs Over Time",
      "query": "SELECT DATE_TRUNC('DAY', CAST(attributes['event.timestamp'] AS TIMESTAMP)) AS time_bucket, COUNT(*) AS pr_count FROM vdm_classic_rikfy0_catalog.zerobus.otel_logs WHERE resource.attributes['service.name'] = 'claude-code' AND attributes['event.name'] = 'tool_result' AND attributes['tool_name'] LIKE '%Bash%' AND body LIKE '%gh pr create%' GROUP BY 1 ORDER BY 1"
    }
  ],
